# Email di notifica quando arriva una candidatura
NOTIFY_EMAIL=info@hreysolutions.com

# Resend (https://resend.com) — lascia vuoto in locale se non usi ancora l'email
RESEND_API_KEY=
RESEND_FROM="Aurex Solutions <onboarding@resend.dev>"

# Opzionale: webhook (Google Apps Script / Make / Zapier) che riceve JSON della candidatura
LEADS_WEBHOOK_URL=

# Contatti pubblici sul sito
NEXT_PUBLIC_CONTACT_EMAIL=info@hreysolutions.com

# URL pubblico del sito (SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://hreysolutions.com

# Analytics (opzionale)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
